# MongoDB connection string
# Local:   mongodb://localhost:27017/cosa_nostra
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/cosa_nostra
MONGO_URI=mongodb+srv://rafayelmadatyan_db_user:37sz331@cluster0.kob24rq.mongodb.net/?appName=Cluster0

# JWT secret key — օգտագործեք երկար, պատահական string
JWT_SECRET=CosaNostra_14e084693b7e6a5705773d4a2ab965d0f70e07c3f69aca4a

# JWT token-ի կյանքը
JWT_EXPIRES_IN=30d

# Server port
PORT=5000

# Ձեր GitHub Pages URL-ն (CORS whitelist-ի համար)
# Օրինակ՝ https://yourusername.github.io
GITHUB_PAGES_URL=https://cosanostra-game.github.io/GameCosaNostra/

# NODE_ENV: development կամ production
NODE_ENV=production
