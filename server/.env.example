# ──────────────────────────────────────────────
#  Cosa Nostra Server — Environment Variables
# ──────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/cosa_nostra
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/cosa_nostra
MONGO_URI=mongodb://localhost:27017/cosa_nostra

# JWT secret key — օգտագործեք երկար, պատահական string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT token-ի կյանքը
JWT_EXPIRES_IN=30d

# Server port
PORT=5000

# Ձեր GitHub Pages URL-ն (CORS whitelist-ի համար)
# Օրինակ՝ https://yourusername.github.io
GITHUB_PAGES_URL=https://yourusername.github.io

# NODE_ENV: development կամ production
NODE_ENV=development
